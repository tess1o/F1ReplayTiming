FROM --platform=$BUILDPLATFORM golang:1.26 AS builder
WORKDIR /src

ARG TARGETOS=linux
ARG TARGETARCH=amd64

COPY backend/go.mod backend/go.sum ./
RUN go mod download
COPY backend/ ./
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH go build -o /out/f1-go-backend .

FROM gcr.io/distroless/static-debian12
WORKDIR /

COPY --from=builder /out/f1-go-backend /f1-go-backend

ENV PORT=8000
ENV DATA_DIR=/data
ENV SQLITE_PATH=/data/f1.db
ENV SQLITE_BUSY_TIMEOUT_MS=5000
ENV REPLAY_CHUNK_FRAMES=256
ENV REPLAY_SAMPLE_INTERVAL_SECONDS=0.25
ENV TELEMETRY_CHUNK_SAMPLES=512
ENV PROCESS_CHUNK_CODEC=protobuf
ENV PROCESS_RAW_MIN_DT_SECONDS=0.10
ENV REPLAY_INTERP_MAX_GAP_SECONDS=1.20

EXPOSE 8000

CMD ["/f1-go-backend"]
