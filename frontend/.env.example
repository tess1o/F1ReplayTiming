# Optional.
# If set, browser calls backend directly (cross-origin): requires backend CORS config.
# If empty, frontend uses same-origin proxy (/api, /ws).
VITE_API_URL=

# Optional proxy upstream used by Nginx for /api and /ws proxying.
# Useful when backend runs outside docker-compose.
BACKEND_INTERNAL_URL=http://f1-backend:8000
